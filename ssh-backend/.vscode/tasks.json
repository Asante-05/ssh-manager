{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Django: Run Server",
      "type": "shell",
      "command": "./venv/bin/python manage.py runserver",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Django: Make + Migrate",
      "type": "shell",
      "command": "./venv/bin/python manage.py makemigrations && ./venv/bin/python manage.py migrate"
    },
    {
      "label": "Django: Migrations",
      "type": "shell",
      "command": "./venv/bin/python manage.py makemigrations"
    },
    {
      "label": "Django: Migrate",
      "type": "shell",
      "command": "./venv/bin/python manage.py migrate"
    },
    {
      "label": "Django: Shell",
      "type": "shell",
      "command": "./venv/bin/python manage.py shell"
    },
    {
      "label": "Django: Create Superuser",
      "type": "shell",
      "command": "./venv/bin/python manage.py createsuperuser"
    },
    {
      "label": "Django: Collect Static",
      "type": "shell",
      "command": "./venv/bin/python manage.py collectstatic --noinput"
    },
    {
      "label": "Show Public Key",
      "type": "shell",
      "command": "cat ~/.ssh/id_ed25519.pub"
    },
    {
  "label": "Test SSH To Windows",
  "type": "shell",
  "command": "ssh asante@192.168.0.172"
}
  ]
}